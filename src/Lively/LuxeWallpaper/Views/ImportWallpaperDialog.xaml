<Window x:Class="LuxeWallpaper.Views.ImportWallpaperDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导入本地壁纸" 
        Height="520" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- 自定义滚动条样式 - 参考图二 -->
        <Style x:Key="CustomScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#5A5A70" 
                                                        CornerRadius="2" 
                                                        Width="4"
                                                        Opacity="0.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ScrollViewer 样式 -->
        <Style x:Key="CustomScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
        
        <!-- 液态玻璃背景效果 - 参考图二 -->
        <Style x:Key="GlassDialog" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#1A1A2E" Opacity="0.90"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="15" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 选择文件按钮样式 - 参考图二 -->
        <Style x:Key="SelectFileButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A40"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3E3E58"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path Data="M9,16V10H5L12,3L19,10H15V16H9M5,20V18H19V20H5Z" 
                                      Fill="{TemplateBinding Foreground}" 
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A50"/>
                    <Setter Property="BorderBrush" Value="#4E4E68"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 取消按钮样式 -->
        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A40"/>
            <Setter Property="Foreground" Value="#B0B0C0"/>
            <Setter Property="BorderBrush" Value="#3E3E58"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A50"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 导入按钮样式 -->
        <Style x:Key="ImportButton" TargetType="Button">
            <Setter Property="Background" Value="#7B5BF5"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#7B5BF5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path Data="M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M14,13V17H10V13H7L12,8L17,13H14Z" 
                                      Fill="{TemplateBinding Foreground}" 
                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B6BF5"/>
                    <Setter Property="BorderBrush" Value="#8B6BF5"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#4A4A60"/>
                    <Setter Property="BorderBrush" Value="#4A4A60"/>
                    <Setter Property="Foreground" Value="#808090"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 关闭按钮样式 -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                  Fill="#B0B0C0" 
                                  Width="14" Height="14" Stretch="Uniform" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A40"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 全局滚动条样式 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#5A5A70" 
                                                        CornerRadius="2" 
                                                        Width="4"
                                                        Opacity="0.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        
        <!-- 弹窗内容 -->
        <Border Style="{StaticResource GlassDialog}" 
                Width="520" Height="460"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 标题栏 -->
                <Grid Grid.Row="0" Margin="20,16,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                               Text="本地导入「不上传云端」" 
                               Foreground="#FFFFFF" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    
                    <Button Grid.Column="1" 
                            Style="{StaticResource CloseButton}"
                            Click="CloseButton_Click"/>
                </Grid>
                
                <!-- 内容区域 -->
                <Grid Grid.Row="1" Margin="20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 提示文字 -->
                    <TextBlock Grid.Row="0" 
                               Text="点击选择壁纸文件「可拖拽」" 
                               Foreground="#FFFFFF" 
                               FontSize="15" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,16"/>
                    
                    <!-- 选择文件按钮 -->
                    <Button Grid.Row="1" 
                            Content="选择文件" 
                            Style="{StaticResource SelectFileButton}"
                            HorizontalAlignment="Center"
                            Click="SelectFileButton_Click"/>
                    
                    <!-- 支持的格式说明 -->
                    <TextBlock Grid.Row="2" 
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               TextAlignment="Center">
                        <Run Text="支持图片格式：png、jpg、jpeg、gif、bmp、webp、avif" Foreground="#6B6B7E" FontSize="11"/>
                        <LineBreak/>
                        <Run Text="支持视频格式：mp4、mov、mkv、webm" Foreground="#6B6B7E" FontSize="11"/>
                    </TextBlock>
                    
                    <!-- 文件计数和预览区域 -->
                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 文件计数 -->
                        <TextBlock Grid.Row="0" 
                                   x:Name="FileCountText"
                                   Text="0 个文件待导入" 
                                   Foreground="#B0B0C0" 
                                   FontSize="13"
                                   Margin="0,0,0,8"/>
                        
                        <!-- 文件列表/空状态 -->
                        <Border Grid.Row="1" 
                                Background="#1E1E32" 
                                CornerRadius="8"
                                BorderBrush="#2E2E48"
                                BorderThickness="1"
                                AllowDrop="True"
                                DragEnter="FileDropArea_DragEnter"
                                DragOver="FileDropArea_DragOver"
                                Drop="FileDropArea_Drop">
                            <Grid>
                                <!-- 空状态 - 盒子图标 -->
                                <StackPanel x:Name="EmptyState" 
                                            VerticalAlignment="Center" 
                                            HorizontalAlignment="Center"
                                            Visibility="Visible">
                                    <Path Data="M12,2L2,7L12,12L22,7L12,2M2,17L12,22L22,17V7L12,12L2,7V17Z" 
                                          Fill="#4A4A60" 
                                          Width="60" Height="60" Stretch="Uniform"
                                          Opacity="0.6"/>
                                </StackPanel>
                                
                                <!-- 文件列表 -->
                                <ScrollViewer x:Name="FileListScrollViewer" 
                                              VerticalScrollBarVisibility="Auto"
                                              Visibility="Collapsed"
                                              Style="{StaticResource CustomScrollViewer}">
                                    <StackPanel x:Name="FileListPanel" Margin="10"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                
                <!-- 底部按钮 -->
                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="20,0,20,16">
                    <Button Content="取消" 
                            Style="{StaticResource CancelButton}"
                            Click="CancelButton_Click"/>
                    <Button Content="导入" 
                            Style="{StaticResource ImportButton}"
                            Margin="10,0,0,0"
                            x:Name="ImportButton"
                            IsEnabled="False"
                            Click="ImportButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
