                                           Style="{StaticResource LiquidGlassTextStyle}"
                                           Foreground="#808090"
                                           Margin="0,0,0,16"/>
                                
                                <!-- 低/中/高 选项 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="RenderLow"
                                            Grid.Column="0"
                                            Content="低"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Click="RenderPerformance_Click"
                                            Tag="Low"/>
                                    <Button x:Name="RenderMedium"
                                            Grid.Column="2"
                                            Content="中"
                                            Style="{StaticResource RenderPerfButtonActiveStyle}"
                                            Click="RenderPerformance_Click"
                                            Tag="Medium"/>
                                    <Button x:Name="RenderHigh"
                                            Grid.Column="4"
                                            Content="高"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Click="RenderPerformance_Click"
                                            Tag="High"/>
                                </Grid>
                            </StackPanel>

                            <!-- 壁纸设置页面 -->
                            <StackPanel x:Name="Page2" Visibility="Collapsed">
                                <TextBlock Text="壁纸设置" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,8"/>
