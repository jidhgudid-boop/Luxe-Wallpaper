                                                  Style="{StaticResource GlassToggleStyle}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- 关于软件页面 -->
                            <StackPanel x:Name="Page6" Visibility="Collapsed">
                                <TextBlock Text="关于软件" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,24"/>
                                
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Luxe Wallpaper" 
                                                   Style="{StaticResource LiquidGlassTitleStyle}"
                                                   FontSize="22"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="版本 1.0.0" 
                                                   Style="{StaticResource LiquidGlassTextStyle}"
                                                   Margin="0,0,0,20"/>
                                        <TextBlock Text="一款精美的动态壁纸应用，让您的桌面焕然一新。" 
                                                   Style="{StaticResource LiquidGlassTextStyle}"
