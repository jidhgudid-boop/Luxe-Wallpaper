                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- 右侧内容区域 -->
                <Border Grid.Column="1" 
                        CornerRadius="0,0,16,0"
                        BorderBrush="#15151525" 
                        BorderThickness="0,1,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="PageContent" Margin="24">
                            
                            <!-- 节能设置页面 -->
                            <StackPanel x:Name="Page0">
                                <TextBlock Text="节能设置" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,24"/>
                                
                                <!-- 启用节能模式 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <CheckBox x:Name="PowerSavingMode"
                                              Style="{StaticResource GlassToggleStyle}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="启用节能模式" 
                                               Style="{StaticResource LiquidGlassLabelStyle}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </StackPanel>
                                
                                <!-- 动态壁纸覆盖阈值 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
                                    <TextBlock Text="动态壁纸被综合覆盖 %" 
                                               Style="{StaticResource LiquidGlassTextStyle}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="PowerThreshold" 
                                              Style="{StaticResource GlassComboBoxStyle}" 
                                              Width="60"
                                              Margin="8,0"
                                              SelectedIndex="8">
                                        <ComboBoxItem Content="40"/>
                                        <ComboBoxItem Content="45"/>
                                        <ComboBoxItem Content="50"/>
                                        <ComboBoxItem Content="55"/>
                                        <ComboBoxItem Content="60"/>
                                        <ComboBoxItem Content="65"/>
                                        <ComboBoxItem Content="70"/>
                                        <ComboBoxItem Content="75"/>
                                        <ComboBoxItem Content="80"/>
                                        <ComboBoxItem Content="85"/>
                                        <ComboBoxItem Content="90"/>
                                        <ComboBoxItem Content="95"/>
                                        <ComboBoxItem Content="100"/>
                                    </ComboBox>
                                    <TextBlock Text="时停止渲染" 
                                               Style="{StaticResource LiquidGlassTextStyle}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 渲染引擎页面 -->
                            <StackPanel x:Name="Page1" Visibility="Collapsed">
                                <TextBlock Text="渲染引擎" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,24"/>
                                
                                <!-- 引擎选择 + 启用硬件加速 -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <ComboBox x:Name="EngineSelector"
                                              Style="{StaticResource GlassComboBoxStyle}" 
                                              Width="140"
                                              Margin="0,0,16,0"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="高性能引擎"/>
                                        <ComboBoxItem Content="多功能引擎"/>
                                    </ComboBox>
                                    <CheckBox x:Name="EnableHardwareAcceleration"
                                              Style="{StaticResource GlassToggleStyle}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
