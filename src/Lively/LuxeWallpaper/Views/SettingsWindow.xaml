                                           Margin="0,0,0,24"/>
                                
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="退出当前账号" 
                                                   Style="{StaticResource LiquidGlassLabelStyle}"
                                                   Margin="0,0,0,8"/>
