                                                   Style="{StaticResource LiquidGlassTextStyle}"
                                                   Margin="0,0,0,20"/>
                                        <Button Style="{StaticResource RenderPerfButtonStyle}"
                                                Width="120"
                                                Height="40"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="退出登录" 
                                                       Style="{StaticResource LiquidGlassLabelStyle}"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
