                            </Button>

                            <!-- 开机自启 -->
                            <Button x:Name="NavStartup" 
                                    Style="{StaticResource NavItemStyle}" 
                                    Margin="0,2"
                                    Click="NavItem_Click"
                                    Tag="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" 
                                          Data="{StaticResource IconStartup}" 
                                          Fill="#B0B0C0"
                                          Width="18" 
                                          Height="18" 
                                          Stretch="Uniform"/>
