                                               Text="开机自启" 
                                               Margin="12,0,0,0"
                                               Foreground="#B0B0C0"/>
                                </Grid>
                            </Button>

                            <!-- 关于软件 -->
                            <Button x:Name="NavAbout" 
                                    Style="{StaticResource NavItemStyle}" 
                                    Margin="0,2"
                                    Click="NavItem_Click"
                                    Tag="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" 
                                          Data="{StaticResource IconAbout}" 
                                          Fill="#B0B0C0"
                                          Width="18" 
                                          Height="18" 
                                          Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="关于软件" 
                                               Margin="12,0,0,0"
                                               Foreground="#B0B0C0"/>
