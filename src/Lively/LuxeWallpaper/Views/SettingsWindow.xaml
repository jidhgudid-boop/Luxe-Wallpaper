                                                       Style="{StaticResource LiquidGlassLabelStyle}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="FadeInOutDisable"
                                            Grid.Column="2"
                                            Height="80"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Click="FadeInOut_Click"
                                            Tag="Disable">
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" 
                                                  Fill="#B0B0C0" 
                                                  Width="24" 
                                                  Height="24"
                                                  Stretch="Uniform"
                                                  Margin="0,0,0,8"/>
                                            <TextBlock Text="禁用" 
                                                       Style="{StaticResource LiquidGlassTextStyle}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                
                                <!-- 速率 -->
                                <TextBlock Text="速率" 
                                           Style="{StaticResource LiquidGlassSubtitleStyle}"
                                           Margin="0,0,0,12"/>
                                <ComboBox x:Name="WallpaperSpeed"
                                          Style="{StaticResource GlassComboBoxStyle}" 
                                          Width="120"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,24"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="常规"/>
                                    <ComboBoxItem Content="快速"/>
                                    <ComboBoxItem Content="慢速"/>
                                </ComboBox>
                                
                                <!-- 锁屏 -->
                                <TextBlock Text="锁屏" 
                                           Style="{StaticResource LiquidGlassSubtitleStyle}"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource YellowButtonStyle}">
                                        <TextBlock Text="解除组织管理" 
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Width="120"
                                            Height="36">
                                        <TextBlock Text="查看说明" 
                                                   Foreground="#FFFFFF" 
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- 下载管理页面 -->
                            <StackPanel x:Name="Page3" Visibility="Collapsed">
                                <TextBlock Text="本地下载管理" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,24"/>
                                
                                <!-- 存储路径 -->
                                <TextBlock Text="存储路径" 
                                           Style="{StaticResource LiquidGlassSubtitleStyle}"
                                           Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" 
                                            Background="#1E1E2E"
                                            BorderBrush="#404050"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Height="44"
                                            Margin="0,0,12,0">
                                        <TextBlock x:Name="DownloadPath" 
                                                   Text="C:\\Users\\admin\\AppData\\Roaming\\Hao Wallpaper\\WallpaperDownload"
                                                   Style="{StaticResource LiquidGlassTextStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Height="44"
                                            Padding="16,0"
                                            Click="BrowseDownloadPath_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M20,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8A2,2 0 0,0 20,6M20,18H4V8H20V18Z" 
                                                  Fill="#FFFFFF" 
                                                  Width="16" 
                                                  Height="16"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="更换存储目录" 
                                                       Foreground="#FFFFFF" 
                                                       FontSize="13"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBlock Text="下载的壁纸文件将保存到此目录下" 
                                           Style="{StaticResource LiquidGlassTextStyle}"
                                           Foreground="#808090"
                                           Margin="0,0,0,24"/>
                                
                                <!-- 下载统计 -->
                                <TextBlock Text="下载统计" 
                                           Style="{StaticResource LiquidGlassSubtitleStyle}"
                                           Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <TextBlock Foreground="#B0B0C0" FontSize="13">
                                        <Run Text="下载中: "/>
                                        <Run Text="0" Foreground="#6B8DD6" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#B0B0C0" FontSize="13" Margin="24,0,0,0">
                                        <Run Text="等待中: "/>
                                        <Run Text="0" Foreground="#E8A838" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#B0B0C0" FontSize="13" Margin="24,0,0,0">
                                        <Run Text="已完成: "/>
                                        <Run Text="1" Foreground="#4CAF50" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </StackPanel>
                                
                                <!-- 管理下载 -->
                                <TextBlock Text="管理下载" 
                                           Style="{StaticResource LiquidGlassSubtitleStyle}"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Background="#8B3A3A"
                                            BorderBrush="#A05050"
                                            Width="140"
                                            Height="44">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                                  Fill="#FFFFFF" 
                                                  Width="16" 
                                                  Height="16"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="清空已下载" 
                                                       Foreground="#FFFFFF" 
                                                       FontSize="13"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource RenderPerfButtonStyle}"
                                            Width="140"
                                            Height="44">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M14,3V5H17.59L7.76,14.83L9.17,16.24L19,6.41V10H21V3M19,19H5V5H12V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V12H19V19Z" 
                                                  Fill="#FFFFFF" 
                                                  Width="16" 
                                                  Height="16"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="打开存储目录" 
                                                       Foreground="#FFFFFF" 
                                                       FontSize="13"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- 检查更新页面 -->
                            <StackPanel x:Name="Page4" Visibility="Collapsed">
                                <TextBlock Text="检查更新" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,24"/>
                                
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="当前版本" 
                                                   Style="{StaticResource LiquidGlassTextStyle}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="v1.0.0" 
                                                   Style="{StaticResource LiquidGlassSubtitleStyle}"
                                                   FontSize="18"
                                                   Margin="0,0,0,20"/>
                                        <Button Style="{StaticResource RenderPerfButtonStyle}"
                                                Width="120"
                                                Height="40"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="检查更新" 
                                                       Style="{StaticResource LiquidGlassLabelStyle}"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 开机自启页面 -->
                            <StackPanel x:Name="Page5" Visibility="Collapsed">
                                <TextBlock Text="开机自启" 
                                           Style="{StaticResource LiquidGlassTitleStyle}"
                                           Margin="0,0,0,24"/>
                                
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="开机自动启动" 
                                                   Style="{StaticResource LiquidGlassLabelStyle}"
                                                   VerticalAlignment="Center"/>
