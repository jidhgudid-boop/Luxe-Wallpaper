                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" 
                                          Data="{StaticResource IconUpdate}" 
                                          Fill="#B0B0C0"
                                          Width="18" 
                                          Height="18" 
                                          Stretch="Uniform"/>
